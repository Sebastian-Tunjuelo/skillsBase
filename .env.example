# .env.example
# 
# Copia este archivo a .env.local y rellena los valores
# NUNCA hagas commit de .env.local a git
#
# Asegúrate de que .gitignore incluya:
#   *.env.local
#   .env.*.local
#

# ============================================================================
# REQUERIDO: GitHub
# ============================================================================
# Cómo obtener:
# 1. Ve a https://github.com/settings/tokens
# 2. Click en "Generate new token (classic)"
# 3. Selecciona scopes: repo, read:org
# 4. Copia el token y pega aquí
#
# Formato: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# OPCIONAL: Información del Repositorio
# ============================================================================
# Normalmente se auto-detecta del origin de git, pero puedes especificar:

# REPO_OWNER=Sebastian-Tunjuelo
# REPO_NAME=skillsBase

# ============================================================================
# OPCIONAL: Rutas del Workspace
# ============================================================================
# Ruta raíz del workspace (normalmente $(pwd))
# WORKSPACE_ROOT=/Users/usuario/Desktop/skillsBase

# ============================================================================
# OPCIONAL: Configuración de Browser (si usas browser MCP)
# ============================================================================
# BROWSER_HEADLESS=true
# BROWSER_TIMEOUT_NAVIGATION=30000
# BROWSER_TIMEOUT_ACTION=5000
